package(default_visibility = ["//visibility:public"])

licenses(["notice"])

cc_library(
    name = "aws_c_s3",
    srcs = glob([
        "source/*.c",
    ]),
    hdrs = glob([
        "include/aws/s3/*.h",
        "include/aws/s3/private/*.h",
    ]),
    copts = [
        "-DCJSON_HIDE_SYMBOLS",
    ],
    includes = [
        "include",
    ],
    deps = [
        "@aws_c_auth",
        "@aws_checksums",
    ],
)
